{
  "name": "react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.mjs",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "dev:backend": "npm run server",
    "dev:frontend": "npm run dev",
    "start:app": "cross-env NODE_ENV=production SERVE_STATIC=1 node server/index.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "preview:prod": "vite preview --host 0.0.0.0 --port 8080",
    "start:sealos": "serve -s out -l tcp://0.0.0.0:8080",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit --project tsconfig.app.json",
    "test:aliyun-ppt": "node scripts/call-aliyun-islide-ppt.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy:tencent-cos": "powershell -ExecutionPolicy Bypass -File scripts/deploy-tencent-cos.ps1"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "@aws-sdk/client-s3": "^3.700.0",
    "@stripe/react-stripe-js": "4.0.2",
    "@supabase/supabase-js": "2.57.4",
    "antd": "^6.3.7",
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "firebase": "12.0.0",
    "i18next": "^25.3.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.469.0",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.1",
    "officeparser": "^6.0.7",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "react": "^19.1.2",
    "react-dom": "^19.1.2",
    "react-i18next": "^15.6.0",
    "react-router-dom": "^7.6.3",
    "recharts": "3.2.0",
    "serve": "^14.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jiti": "^2.6.1",
    "postcss": "^8.5.6",
    "source-map": "^0.7.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "unplugin-auto-import": "^19.3.0",
    "vite": "^8.0.1",
    "vitest": "^3.0.0"
  }
}
